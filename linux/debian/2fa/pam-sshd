# PAM Configuration for SSH Key + Google Authenticator 2FA
# Used in /etc/pam.d/sshd

# Require Google Authenticator (TOTP) as first step
auth       required     pam_google_authenticator.so

# Optional Unix authentication (only proceeds if 2FA succeeds)
auth       optional     pam_unix.so no_warn try_first_pass

# Account and session management
account    required     pam_unix.so
session    required     pam_unix.so
