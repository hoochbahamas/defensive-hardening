# =====================================================
# Defensive Hardening - SSH Configuration
# Debian 13 | Portfolio Project
# Rank 1: SSH Service Hardening
# =====================================================

# Port Configuration
Port 50022

# Authentication Security
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
KbdInteractiveAuthentication yes
UsePAM yes
ChallengeResponseAuthentication yes

# Brute Force & Session Protection
MaxAuthTries 3
MaxSessions 2
LoginGraceTime 30

# User Restriction
AllowUsers rober

# Session Management & Keepalive
ClientAliveInterval 300
ClientAliveCountMax 2
TCPKeepAlive yes

# Logging (Important for Fail2Ban and auditing)
LogLevel VERBOSE

# Additional Security Best Practices
PermitEmptyPasswords no
StrictModes yes
IgnoreRhosts yes
HostbasedAuthentication no
PermitTunnel no
